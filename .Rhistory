library(sf)
library(dplyr)
library(ggplot2)
library(stringr)
mg <- st_read(
"C:/Users/Usuario/Downloads/MG_Municipios_2025/MG_Municipios_2025.shp",
quiet = TRUE
)
ac_por_muni <- acidentes %>%
count(municipio)
ac_por_muni$municipio <- str_to_upper(
ac_por_muni$municipio
)
mg$NM_MUN <- str_to_upper(
mg$NM_MUN
)
mapa_final <- mg %>%
left_join(
ac_por_muni,
by = c("NM_MUN" = "municipio")
) %>%
mutate(
faixa = case_when(
n >= 300 ~ "300+",
n >= 200 ~ "200 - 299",
n >= 100 ~ "100 - 199",
n >= 50  ~ "50 - 99",
n >= 1   ~ "1 - 49",
TRUE ~ "Sem registros"
)
)
ggplot(mapa_final) +
geom_sf(
aes(fill = faixa),
color = "gray70",
size = 0.08
) +
scale_fill_manual(
values = c(
"300+" = "#084081",
"200 - 299" = "#0868ac",
"100 - 199" = "#2b8cbe",
"50 - 99" = "#7bccc4",
"1 - 49" = "#d9e6f2",
"Sem registros" = "#f5f5f5"
)
) +
coord_sf(
xlim = c(-51, -40),
ylim = c(-23, -14),
expand = FALSE
) +
labs(
title = "Distribuição de acidentes por município em Minas Gerais",
subtitle = "Municípios classificados por faixa de acidentes",
fill = "Acidentes"
) +
theme_void() +
theme(
plot.title = element_text(
size = 18,
face = "bold",
hjust = 0.5
),
plot.subtitle = element_text(
size = 11,
hjust = 0.5,
color = "gray40"
),
legend.position = "bottom",
legend.title = element_text(
face = "bold"
),
legend.text = element_text(
size = 9
)
)

library(sf)
library(dplyr)
library(ggplot2)
library(stringr)
# Ler shapefile
mg <- st_read("C:/Users/Usuario/Downloads/MG_Municipios_2025/MG_Municipios_2025.shp")
# Contar acidentes por município
ac_por_muni <- acidentes %>%
count(municipio)
# Padronizar nomes
ac_por_muni$municipio <- str_to_upper(ac_por_muni$municipio)
mg$NM_MUN <- str_to_upper(mg$NM_MUN)
# Juntar banco com mapa
mapa_final <- mg %>%
left_join(ac_por_muni,
by = c("NM_MUN" = "municipio"))
ggplot(mapa_final) +
geom_sf(
aes(fill = n),
color = "gray85",
size = 0.08
) +
scale_fill_gradient(
low = "#dbe9f6",
high = "#08519c",
na.value = "gray95"
) +
labs(
title = "Quantidade de acidentes por município em Minas Gerais",
fill = "Acidentes"
) +
coord_sf() +
tema_projeto() +
theme(
axis.text = element_blank(),
axis.ticks = element_blank(),
panel.grid = element_blank(),
panel.background = element_rect(
fill = "white",
color = NA
)
)
# =========================
# PACOTES NECESSÁRIOS
# =========================
install.packages(c(
"sf",
"dplyr",
"ggplot2",
"stringr",
"viridis",
"osmdata",
"ggrepel"
))
# =========================
# BIBLIOTECAS
# =========================
library(sf)
library(dplyr)
library(ggplot2)
library(stringr)
library(viridis)
library(osmdata)
library(ggrepel)
# =========================
# TEMA DO PROJETO
# =========================
tema_projeto <- function(){
theme_classic() +
theme(
plot.title = element_text(
size = 14,
face = "bold",
hjust = 0.5,
margin = margin(b = 12)
),
axis.title = element_text(
size = 11
),
axis.text = element_text(
size = 10,
color = "black"
),
legend.position = "bottom",
legend.title = element_text(
face = "bold"
),
panel.border = element_blank(),
plot.margin = margin(
15, 15, 15, 15
)
)
}
# =========================
# LER SHAPEFILE
# =========================
mg <- st_read(
"C:/Users/Usuario/Downloads/MG_Municipios_2025/MG_Municipios_2025.shp"
)
# =========================
# CONTAR ACIDENTES
# =========================
ac_por_muni <- acidentes %>%
count(municipio)
# =========================
# PADRONIZAR NOMES
# =========================
ac_por_muni$municipio <- str_to_upper(
ac_por_muni$municipio
)
mg$NM_MUN <- str_to_upper(
mg$NM_MUN
)
# =========================
# JUNTAR DADOS
# =========================
mapa_final <- mg %>%
left_join(
ac_por_muni,
by = c("NM_MUN" = "municipio")
)
# =========================
# BUSCAR RODOVIAS
# =========================
rodovias <- opq("Minas Gerais, Brazil") %>%
add_osm_feature(
key = "highway",
value = c(
"motorway",
"trunk",
"primary"
)
) %>%
osmdata_sf()
# =========================
# TOP 10 MUNICÍPIOS
# =========================
top10 <- mapa_final %>%
slice_max(n, n = 10)
centros <- st_centroid(top10)
# =========================
# MAPA FINAL
# =========================
ggplot() +
# Municípios
geom_sf(
data = mapa_final,
aes(fill = n),
color = "gray70",
size = 0.04
) +
# Contorno externo
geom_sf(
data = mapa_final,
fill = NA,
color = "black",
size = 0.15
) +
# Rodovias
geom_sf(
data = rodovias$osm_lines,
color = "black",
size = 0.2,
alpha = 0.35
) +
# Nome dos municípios principais
geom_text_repel(
data = centros,
aes(
geometry = geometry,
label = NM_MUN
),
stat = "sf_coordinates",
size = 3
) +
# Escala de cores
scale_fill_viridis_c(
option = "inferno",
na.value = "gray95"
) +
# Títulos
labs(
title = "Quantidade de acidentes por município em Minas Gerais",
fill = "Acidentes"
) +
# Tema
tema_projeto() +
# Ajustes finais
theme(
axis.text = element_blank(),
axis.ticks = element_blank(),
panel.grid = element_blank(),
panel.background = element_rect(
fill = "white",
color = NA
)
)
# =========================
# PACOTES NECESSÁRIOS
# =========================
install.packages(c(
"sf",
"dplyr",
"ggplot2",
"stringr",
"viridis",
"osmdata",
"ggrepel"
))

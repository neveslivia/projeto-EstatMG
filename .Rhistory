data = mapa_mg,
aes(
x = long,
y = lat,
group = group
),
fill = "gray95",
color = "white"
) +
geom_point(
data = acidentes,
aes(
x = longitude,
y = latitude
),
color = "#355070",
alpha = 0.35,
size = 0.7
) +
labs(
title = "Distribuição Espacial dos Acidentes em Minas Gerais"
) +
coord_fixed(1.3) +
theme_void() +
theme(
plot.title = element_text(
size = 14,
face = "bold",
hjust = 0.5
)
)
